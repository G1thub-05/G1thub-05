	// ✨ Highlight Related Setting
	"highlight-matching-tag.highlightFromContent": true,
	"highlight-matching-tag.highlightSelfClosing": true,
	"highlight-matching-tag.matchingTagBackground": "#155FFA",
	"highlight-matching-tag.styles": {
		"opening": {
			"left": {
				"underline": "yellow",
				"surround": "#155FFA",
			},
			"full": {
				"underline": "yellow",
				"surround": "#155FFA",
			},
			"right": {
				"underline": "yellow",
				"surround": "#155FFA",
			},
			"name": {
				"underline": "yellow",
				"surround": "#155FFA",
			},
		},
		"right": {
			"surround": "#155FFA",
		},
		"name": {
			"highlight": "rgba(180, 20, 80, 0.3)",
		},
	},

	// ✏️ Editor Setting
	"editor.wordWrap": "on",
	"editor.columnSelection": false,
	"editor.renderWhitespace": "boundary",
	"editor.fontFamily": "CascadiaMonoNF-LightItalic ,Consolas, 'Courier New', monospace",
