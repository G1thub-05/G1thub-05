	// 🪪 Workbench Related Setting
	"workbench.iconTheme": "vscode-icons",
	"workbench.startupEditor": "none",
	"workbench.statusBar.visible": true,
	"workbench.editor.highlightModifiedTabs": true,
	"workbench.activityBar.location": "top",
	"workbench.list.smoothScrolling": true,
	"workbench.preferredDarkColorTheme": "Visual Studio Dark",
	"workbench.preferredHighContrastLightColorTheme": "Tinacious Design (High Contrast)",
	"workbench.colorTheme": "Tinacious Design (High Contrast)",
	"workbench.colorCustomizations": {
		"terminal.background": "#0f0f1f", // for transparent  use"#00000000",
		"statusBar.background": "#0f0f1f",
		"statusBar.foreground": "#ffffff",
		"editor.selectionForeground": "#ffffff",
		"editor.inactiveSelectionBackground": "#264f7840",
		"editor.selectionBackground": "#fdfdfd41",
		"editor.selectionHighlightBackground": "#0078d440",
	},

	"workbench.settings.applyToAllProfiles": [
		"animations.UseCursorColorForCursorAnimation",
	],
	"workbench.editorAssociations": {
		"*.copilotmd": "vscode.markdown.preview.editor",
		"*.svg": "default",
	},

	// 🔥Power Mode Setting
	"powermode.enabled": false,
	"powermode.combo.counterEnabled": "hide",
	"powermode.combo.counterSize": 0,
	"powermode.combo.timerEnabled": "hide",
	"powermode.shake.intensity": 2,
	"powermode.shake.enabled": false,
	"powermode.presets": "flames",
	"powermode.explosions.backgroundMode": "image",

	// 🪟 Windows Related Setting
	"window.newWindowProfile": "Default",
	"window.menuBarVisibility": "toggle",
	"window.confirmBeforeClose": "always",
	"window.density.editorTabHeight": "compact",
	"window.dialogStyle": "custom",
	"window.titleBarStyle": "native",
	"window.commandCenter": false,

	// 📁 File Related Setting
	"files.trimTrailingWhitespace": true,
	"files.autoSaveWhenNoErrors": true,
	"files.autoSave": "afterDelay",
	"files.autoSaveDelay": 0,

	// 🪪 Terminal Related Setting
	"terminal.integrated.fontFamily": "monospace",
	"terminal.integrated.cursorBlinking": true,
	"terminal.integrated.cursorStyle": "line",
	"terminal.integrated.cursorStyleInactive": "block",
	"terminal.integrated.smoothScrolling": true,
	"terminal.integrated.suggest.enabled": true,
	"terminal.integrated.tabs.defaultColor": "terminal.ansiCyan",
	"terminal.integrated.confirmOnExit": "always",
	"terminal.integrated.gpuAcceleration": "auto",

	// ▶️ Code Runner Related Setting
	"code-runner.fileDirectoryAsCwd": true,
	"code-runner.saveAllFilesBeforeRun": true,
	"code-runner.saveFileBeforeRun": true,
	"code-runner.clearPreviousOutput": true,

